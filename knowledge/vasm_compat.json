{
  "_meta": {
    "description": "vasm M68K assembler compatibility data",
    "assembler": "vasmm68k_mot",
    "version": "2.0e",
    "cpu_flags": ["-m68000", "-m68010", "-m68020", "-m68030", "-m68040", "-m68060", "-m68020up", "-m68881", "-m68882", "-m68851", "-mcpu32"],
    "default_cpu_flag_map": {
      "68000": "-m68000",
      "68010": "-m68010",
      "68020": "-m68020",
      "68030": "-m68030",
      "68040": "-m68040",
      "cpu32": "-mcpu32"
    }
  },
  "instructions": {
    "cpBcc": {
      "supported": false,
      "reason": "Generic coprocessor interface not implemented — vasm only knows specific coprocessors (FPU/MMU)"
    },
    "cpDBcc": {
      "supported": false,
      "reason": "Generic coprocessor interface not implemented"
    },
    "cpGEN": {
      "supported": false,
      "reason": "Generic coprocessor interface not implemented"
    },
    "cpScc": {
      "supported": false,
      "reason": "Generic coprocessor interface not implemented"
    },
    "cpTRAPcc": {
      "supported": false,
      "reason": "Generic coprocessor interface not implemented"
    },
    "cpRESTORE": {
      "supported": false,
      "reason": "Generic coprocessor interface not implemented"
    },
    "cpSAVE": {
      "supported": false,
      "reason": "Generic coprocessor interface not implemented"
    },
    "PBcc": {
      "supported": false,
      "reason": "Bundled vasm parser does not accept PBcc syntax via this harness"
    },
    "PDBcc": {
      "supported": false,
      "reason": "Bundled vasm parser does not accept PDBcc syntax via this harness"
    },
    "PFLUSH": {
      "supported": false,
      "reason": "Bundled vasm parser does not accept PFLUSH control-register forms via this harness"
    },
    "PFLUSH PFLUSHA": {
      "cpu_flag": "-m68851",
      "notes": "68851 PFLUSH/PFLUSHA forms"
    },
    "PFLUSHR": {
      "cpu_flag": "-m68851",
      "notes": "PMMU instruction"
    },
    "PLOAD": {
      "supported": false,
      "reason": "Bundled vasm parser does not accept PLOAD syntax via this harness"
    },
    "PMOVE": {
      "supported": false,
      "reason": "Bundled vasm parser does not accept PMOVE control-register forms via this harness"
    },
    "PRESTORE": {
      "cpu_flag": "-m68851",
      "notes": "PMMU instruction"
    },
    "PSAVE": {
      "cpu_flag": "-m68851",
      "notes": "PMMU instruction"
    },
    "PScc": {
      "cpu_flag": "-m68851",
      "notes": "PMMU instruction"
    },
    "PTEST": {
      "supported": false,
      "reason": "Bundled vasm parser does not accept PTEST syntax via this harness"
    },
    "PTRAPcc": {
      "cpu_flag": "-m68851",
      "notes": "PMMU instruction"
    },
    "PVALID": {
      "supported": false,
      "reason": "Bundled vasm parser does not accept PVALID syntax via this harness"
    },
    "BKPT": {
      "cpu_flag": "-m68010",
      "notes": "MC68EC000/68010+ instruction; base 68000 does not support BKPT"
    },
    "BFCHG": {
      "cpu_flag": "-m68020",
      "notes": "Bit-field instructions require 68020+"
    },
    "BFCLR": {
      "cpu_flag": "-m68020",
      "notes": "Bit-field instructions require 68020+"
    },
    "BFEXTS": {
      "cpu_flag": "-m68020",
      "notes": "Bit-field instructions require 68020+"
    },
    "BFEXTU": {
      "cpu_flag": "-m68020",
      "notes": "Bit-field instructions require 68020+"
    },
    "BFFFO": {
      "cpu_flag": "-m68020",
      "notes": "Bit-field instructions require 68020+"
    },
    "BFINS": {
      "cpu_flag": "-m68020",
      "notes": "Bit-field instructions require 68020+"
    },
    "BFSET": {
      "cpu_flag": "-m68020",
      "notes": "Bit-field instructions require 68020+"
    },
    "BFTST": {
      "cpu_flag": "-m68020",
      "notes": "Bit-field instructions require 68020+"
    },
    "CAS CAS2": {
      "cpu_flag": "-m68020",
      "skip_forms": ["cas2"],
      "notes": "CAS works; CAS2 uses (Rn1):(Rn2) syntax not yet supported in test generator"
    },
    "CHK2": {
      "cpu_flag": "-m68020",
      "notes": "CHK2/CMP2 require 68020+"
    },
    "CMP2": {
      "cpu_flag": "-m68020",
      "notes": "CHK2/CMP2 require 68020+"
    },
    "MOVE16": {
      "cpu_flag": "-m68040",
      "skip_forms": ["move16 (xxx).l"],
      "notes": "Postinc form works; absolute address forms have no test generator support yet"
    },
    "MOVEP": {
      "notes": "Works with default -m68000"
    },
    "PACK": {
      "cpu_flag": "-m68020",
      "notes": "68020+ BCD pack instruction"
    },
    "UNPK": {
      "cpu_flag": "-m68020",
      "notes": "68020+ BCD unpack instruction"
    },
    "MOVE USP": {
      "cpu_flag": "-m68010",
      "notes": "Privileged instruction; requires supervisor mode — vasm assembles it"
    },
    "MOVEC": {
      "cpu_flag": "-m68010",
      "notes": "68010+ control register move"
    },
    "MOVES": {
      "cpu_flag": "-m68010",
      "notes": "68010+ alternate address space move"
    },
    "RTM": {
      "cpu_flag": "-m68020",
      "notes": "68020 return from module"
    },
    "CPUSH": {
      "supported": false,
      "reason": "Bundled vasm parser does not include CPUSH in this extraction"
    },
    "CINV": {
      "supported": false,
      "reason": "Bundled vasm parser does not include CINV in this extraction"
    },
    "MOVE from CCR": {
      "cpu_flag": "-m68010",
      "notes": "MOVE CCR,<ea> is a 68010+ instruction"
    },
    "EXT, EXTB": {
      "skip_forms": ["extb"],
      "notes": "vasm syntax does not accept EXTB in tested form"
    },
    "FRESTORE": {
      "cpu_flag": "-m68881",
      "notes": "FPU coprocessor instruction; needs FPU flag, not just 68020"
    },
    "FSAVE": {
      "cpu_flag": "-m68881",
      "notes": "FPU coprocessor instruction; needs FPU flag, not just 68020"
    },
    "TRAPcc": {
      "notes": "Size suffix (.w/.l) required on immediate forms per M68K convention"
    }
  },
  "branch_size_map": {
    "_comment": "Maps KB encoding size letters to vasm branch suffixes and test constraints",
    "b": {"suffix": ".s", "needs_nop_filler": true},
    "w": {"suffix": ".w", "needs_nop_filler": false},
    "l": {"suffix": ".l", "needs_nop_filler": false, "skip_for_68000": true}
  }
}
