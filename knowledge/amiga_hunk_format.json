      "citation": "LOADSEG.ASM lines 238-261: lssHunkReloc32 uses GetLong (ULONG) for count, target, and each offset"
    },
    "short": {
      "description": "Compact 16-bit reloc format",
      "fields": [
        {
          "name": "count",
          "type": "UWORD",
          "note": "Number of offsets; 0 = terminator"
        },
        {
          "name": "target_hunk",
          "type": "UWORD"
        },
        {
          "name": "offsets",
          "type": "UWORD[]",
          "note": "count \u00d7 reloc offsets (16-bit, max 64K)"
        }
      ],
      "terminator": "count == 0, then align to longword boundary",
      "applies_to": [
        "HUNK_RELOC32SHORT"
      ],
      "citation": "DOSHUNKS.H lines 42-47: V37 LoadSeg uses HUNK_DREL32 (1015) for this format in load files. HUNK_DREL32 is illegal in load files, so 1015 unambiguously means short relocs in executables."
    }
  },
