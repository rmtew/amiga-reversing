{
  "_meta": {
    "schema": "asm_oracle_v1",
    "description": "DevPac GenAm 3.18 assembler behavior documentation",
    "source": "Empirical testing via vamos against instruction variants",
    "version": "3.18",
    "test_date": "2026-03-13"
  },
  "syntax_family": "motorola",
  "local_include_root": "ext/amiga_includes/ndk_2.0/include",
  "cli": {
    "executable": "GenAm",
    "usage": "GenAm FROM/A TO/K WITH/K INCDIR/K/M HEADER/K/M QUIET/S",
    "output_formats": {
      "amiga_executable": "default",
      "alink_object": "-L3",
      "srec": "-L6"
    },
    "notes": "GenAm always wraps output in Amiga hunk format; no raw binary equivalent"
  },
  "options": {
    "cpu_select": "OPT P=68000",
    "no_optimization": "OPT O-",
    "quiet": "QUIET",
    "output_file": "TO <filename>",
    "output_file_short": "-O<filename>"
  },
  "driver": {
    "type": "vamos",
    "executable_path": "bin/GenAm",
    "batch_size": 50,
    "sentinel_word": "0xA5A5"
  },
  "render_profile": {
    "assembler_id": "devpac",
    "header_generated_syntax": "GenAm Motorola syntax",
    "comment_prefix": ";",
    "blank_line": "",
    "line_ending": "lf",
    "string_delimiters": ["\"", "'"],
    "current_location_token": "*",
    "omit_zero_pc_index_displacement": false,
    "require_label_anchor_for_self_relative_data": true,
    "auto_align_dc_w": true,
    "auto_align_dc_l": true,
    "unsupported_hint_operand_kinds": [
      "memory_indirect_indexed",
      "pc_memory_indirect_indexed"
    ],
    "directives": {
      "include": "INCLUDE",
      "section": "SECTION",
      "equ": "EQU",
      "dc_b": "DC.B",
      "dc_w": "DC.W",
      "dc_l": "DC.L",
      "ds_b": "DS.B",
      "dcb_b": "DCB.B"
    }
  },
  "platform_notes": {
    "return_codes": {
      "0": "OK",
      "5": "warnings",
      "10": "errors",
      "20": "fatal",
      "100+": "initialization failure"
    },
    "auto_config": {
      "opts_file": "GenAm.opts",
      "behavior": "Auto-loaded from GenAm's directory if present",
      "vamos_issue": "incdir paths in shipped opts file don't exist under vamos, causing errors"
    },
    "directives": {
      "org": {
        "syntax": "ORG <expression>",
        "restriction": "Not allowed for linkable code (default Amiga executable mode)",
        "source": "DevPac 3.00 manual"
      },
      "pc_relative_star": {
        "syntax": "*+N or *-N",
        "notes": "Used for branch targets in testing since ORG is forbidden in default executable mode"
      }
    },
    "option_notes": "Each OPT must be on its own line; comma-separated OPTs on one line cause errors"
  },
  "encoding_behaviors": [
    {
      "id": "imm_dn_auto_route",
      "description": "Routes ADD/AND/OR/SUB/EOR #imm,Dn to dedicated immediate instruction, but NOT CMP",
      "affected_mnemonics": ["ADD", "AND", "OR", "SUB", "EOR"],
      "not_affected": ["CMP"],
      "both_valid": true,
      "example": {
        "input": "add.b #$12,d1",
        "this_encoding": "06010012",
        "other_encoding": "d23c0012"
      }
    }
  ],
  "tested": {
    "total_tests": 1301,
    "passed": 1297,
    "mismatches": 0,
    "known_divergences": 4,
    "oracle_errors": 5,
    "mnemonics_tested": 90,
    "mismatch_categories": {},
    "known_divergence_categories": {
      "cmp_imm_routing": 3,
      "exg_commutative": 1
    },
    "oracle_error_categories": {
      "020_plus_instructions": 5
    }
  }
}
