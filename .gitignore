# Claude Code local settings
.claude/settings.local.json

# Temporary/transient files
tmp/*
!tmp/.gitkeep

# Python venv
.venv/

# Build artifacts
bin/rebuilt/
ext/vasm.tar.gz
*.o
*.obj
*.exe
*.pyc
__pycache__/
*.prof

# External resources (copyrighted / user-supplied, see RESOURCES.md)
bin/*
!bin/.gitkeep
resources/*
