# Per-target output (entities, disassembly, progress)
targets/*
!targets/.gitkeep
!targets/*/
targets/*/*
!targets/*/*.s
!targets/*/benchmark.json
!targets/*/binary_path.txt
!targets/*/source_disk.json
!targets/.disks/
!targets/.disks/*/
!targets/.disks/*/manifest.json
*.analysis
